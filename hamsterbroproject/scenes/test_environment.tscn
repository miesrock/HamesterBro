[sub_resource type="Shader" id="Sh_chk"]
resource_name = "CheckerboardShader"
code = "
shader_type spatial;

uniform vec4 color1 : source_color = vec4(0.7, 0.7, 0.7, 1.0);
uniform vec4 color2 : source_color = vec4(0.5, 0.5, 0.5, 1.0);
uniform float scale : hint_range(0.1, 10.0) = 2.0;

void fragment() {
	vec2 uv = UV * scale;
	float val = step(0.5, mod(floor(uv.x) + floor(uv.y), 2.0));
	ALBEDO = mix(color1, color2, val).rgb;
}
"

